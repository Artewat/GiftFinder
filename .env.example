# Postgres
POSTGRES_USER=giftfinder
POSTGRES_PASSWORD=giftfinder
POSTGRES_DB=giftfinder

# nano-gpt (OpenAI-compatible client)
NANOGPT_API_KEY=changeme
NANOGPT_BASE_URL=https://nano-gpt.com/api/v1
NANOGPT_MODEL=deepseek/deepseek-v3.2

# Embeddings
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Подтверждение email
# console — ссылка печатается в лог backend (dev); smtp — точка расширения
EMAIL_BACKEND=console
EMAIL_FROM=no-reply@giftfinder.local
VERIFY_TOKEN_TTL_HOURS=24
RESEND_COOLDOWN_SECONDS=60
# Заполнять только при EMAIL_BACKEND=smtp:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
