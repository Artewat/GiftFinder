# Postgres
POSTGRES_USER=giftfinder
POSTGRES_PASSWORD=giftfinder
POSTGRES_DB=giftfinder

# nano-gpt (OpenAI-compatible client)
NANOGPT_API_KEY=changeme
NANOGPT_BASE_URL=https://nano-gpt.com/api/v1
NANOGPT_MODEL=deepseek/deepseek-v3.2

# Embeddings
EMBEDDING_MODEL=intfloat/multilingual-e5-base

# Подтверждение email по 6-значному коду
# console — код печатается в лог backend (dev); smtp — реальная отправка письма
EMAIL_BACKEND=console
VERIFY_CODE_LENGTH=6
VERIFY_CODE_TTL_MINUTES=15
MAX_VERIFY_ATTEMPTS=5
RESEND_COOLDOWN_SECONDS=60
# Реальная отправка через Яндекс (заполнять при EMAIL_BACKEND=smtp).
# SMTP_PASSWORD — это «пароль приложения» Яндекса (Яндекс ID → Пароли приложений),
# НЕ основной пароль; нужна включённая двухфакторка. Только в .env, не в git.
# EMAIL_FROM должен совпадать с SMTP_USER (Яндекс не шлёт «от чужого имени»).
SMTP_HOST=smtp.yandex.ru
SMTP_PORT=465
SMTP_USER=your-address@yandex.ru
SMTP_PASSWORD=
EMAIL_FROM=your-address@yandex.ru
